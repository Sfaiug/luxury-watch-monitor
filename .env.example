# Watch Monitor Production Configuration
# Copy this file to .env and fill in your actual webhook URLs

# ==========================================
# DISCORD WEBHOOK CONFIGURATION (REQUIRED)
# ==========================================
# Get these from Discord Server Settings > Integrations > Webhooks

WORLDOFTIME_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
GRIMMEISSEN_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
TROPICALWATCH_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
JUWELIER_EXCHANGE_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
WATCH_OUT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
RUESCHENBECK_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# MUV action/result notifications
# Used when a Discord button click has prepared/submitted/failed a MUV action.
MUV_RESULT_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# ==========================================
# DISCORD INTERACTION BUTTONS FOR MUV
# ==========================================
# Create a Discord application, set its Interactions Endpoint URL to:
# https://YOUR_DOMAIN/discord/interactions
# The VM must expose this endpoint through HTTPS, e.g. nginx/Caddy/Cloudflare.

ENABLE_MUV_ACTIONS=false
DISCORD_INTERACTIONS_ENABLED=false
DISCORD_PUBLIC_KEY=
ACTION_TOKEN_SECRET=
DISCORD_INTERACTIONS_HOST=0.0.0.0
DISCORD_INTERACTIONS_PORT=8080
DISCORD_INTERACTIONS_PATH=/discord/interactions
MUV_OFFER_WEBHOOK_PATH=/muv/offers
ACTION_STORE_FILE=muv_actions.sqlite3
MUV_ACTION_LABEL=Send to MUV

# MUV request handling. Auto-submit is blocked unless all required seller,
# legal, and image settings are present.
MUV_BASE_URL=https://www.meineuhrverkaufen.de
MUV_SUBMISSION_MODE=prepare
MUV_AUTO_SUBMIT=false
MUV_MATCH_THRESHOLD=0.72
MUV_MIN_PICTURE_COUNT=3
MUV_DEFAULT_CONDITION=3
MUV_SELLER_EMAIL=
MUV_SELLER_FIRST_NAME=
MUV_SELLER_LAST_NAME=
MUV_ACCEPT_TERMS=false
MUV_CONFIRM_EU_SELLER=false

# ==========================================
# MONITORING CONFIGURATION (OPTIONAL)
# ==========================================
# Adjust these based on your server capacity and target site policies

# Check interval in seconds (default: 180 = 3 minutes).
# After payload optimizations, 180 is the first conservative faster target.
CHECK_INTERVAL_SECONDS=180

# Maximum concurrent scrapers (default: 2)
# Higher values may trigger bot detection
MAX_CONCURRENT_SCRAPERS=2

# Maximum concurrent detail page fetches per site (default: 5)
MAX_CONCURRENT_DETAILS=5

# Detail page fetch delay in seconds (default: 1.5)
# Prevents overwhelming target sites
DETAIL_PAGE_DELAY=1.5

# ==========================================
# HTTP CONFIGURATION (OPTIONAL)
# ==========================================

# Request timeout in seconds (default: 15)
REQUEST_TIMEOUT=15

# Number of retry attempts for failed requests (default: 3)
MAX_RETRIES=3

# Exponential backoff factor for retries (default: 2.0)
RETRY_BACKOFF_FACTOR=2.0

# User agent string (default: Chrome on Windows)
# USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ==========================================
# DATA PERSISTENCE (OPTIONAL)
# ==========================================

# File paths for data storage
SEEN_WATCHES_FILE=seen_watches.json
SESSION_HISTORY_FILE=session_history.json

# Maximum number of seen items to track per site (default: 10000)
MAX_SEEN_ITEMS_PER_SITE=10000

# Session history retention in days (default: 30)
SESSION_HISTORY_RETENTION_DAYS=30

# ==========================================
# FEATURE FLAGS (OPTIONAL)
# ==========================================

# Enable Discord notifications (default: true)
ENABLE_NOTIFICATIONS=true

# Enable detail page scraping (default: true)
# Set to false for faster but less detailed monitoring
ENABLE_DETAIL_SCRAPING=true

# Enable USD to EUR conversion for Tropical Watch (default: true)
ENABLE_EXCHANGE_RATE_CONVERSION=true

# ==========================================
# EXCHANGE RATE API (OPTIONAL)
# ==========================================

# Exchange rate API URL (default: exchangerate-api.com)
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD

# Cache duration for exchange rates in seconds (default: 3600 = 1 hour)
EXCHANGE_RATE_CACHE_DURATION=3600

# ==========================================
# WINDOWS SERVICE CONFIGURATION (OPTIONAL)
# ==========================================
# Only needed when running as Windows service

# Service display name
# SERVICE_NAME=WatchMonitor

# Service description
# SERVICE_DESCRIPTION=Luxury Watch Monitoring Service

# Auto-restart on failure (default: true)
# SERVICE_AUTO_RESTART=true

# Maximum restart attempts (default: 3)
# SERVICE_MAX_RESTARTS=3
